# .env.example – copy to .env and fill in your values

#REQUIRED
# Groq API (required)
GROQ_API_KEY=your_groq_api_key_here


#OPTIONAL
# Groq model (optional, default: mixtral-8x7b-32768)
# GROQ_MODEL=mixtral-8x7b-32768

# LLM temperature (optional, default: 0.0)
# GROQ_TEMPERATURE=0.0

# Max output tokens (optional, default: 1024)
# GROQ_MAX_TOKENS=1024

# Redis connection (optional, default: redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Redis TTL seconds (optional, default: 3600)
# REDIS_TTL_SECONDS=3600

# Redis max connections (optional, default: 10)
# REDIS_MAX_CONNECTIONS=10

# Chroma persist directory (optional, default: ./chroma_cache)
# CHROMA_PERSIST_DIRECTORY=./chroma_cache

# Semantic similarity threshold (optional, default: 0.92)
# SIMILARITY_THRESHOLD=0.92

# Embedding model name (optional, default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Semantic cache max entries (LRU) (optional, default: 10000)
# MAX_SEMANTIC_CACHE_ENTRIES=10000

# LRU check frequency (optional, default: 100)
# SEMANTIC_CACHE_LRU_CHECK_FREQUENCY=100

# Token control (optional)
# MAX_PROMPT_TOKENS=7000
# TOKEN_ENCODER_NAME=cl100k_base
# OVERFLOW_STRATEGY=reject
# TRUNCATION_KEEP_START_RATIO=0.6

# Summarisation settings (optional)
# SUMMARIZATION_MODEL=llama3-8b-8192
# SUMMARIZATION_MAX_TOKENS=512
# SUMMARIZATION_KEEP_RATIO=0.7

# Performance (optional)
# REQUEST_TIMEOUT_SECONDS=30.0
# RETRY_ATTEMPTS=3
# RETRY_BACKOFF_FACTOR=1.0

# Logging (optional, default: INFO)
# LOG_LEVEL=INFO